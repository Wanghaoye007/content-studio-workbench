NODE_ENV=production
CONTENT_STUDIO_SECURE_COOKIES=true
CONTENT_STUDIO_PERSISTENCE_BACKEND=sqlite

# Internal production service: keep loopback-only.
CONTENT_STUDIO_HOST=127.0.0.1
CONTENT_STUDIO_PORT=4173

# HTTPS endpoint visible to the trusted LAN.
CONTENT_STUDIO_LAN_HOST=10.10.2.106
CONTENT_STUDIO_LAN_PORT=8443
CONTENT_STUDIO_PUBLIC_BASE_URL=https://10.10.2.106:8443
CONTENT_STUDIO_LAN_TLS_CERT_FILE=/opt/content-studio/tls/server.crt
CONTENT_STUDIO_LAN_TLS_KEY_FILE=/opt/content-studio/tls/server.key

CONTENT_STUDIO_RELEASE_ARTIFACT_DIR=/path/to/content-studio-workbench/dist
CONTENT_STUDIO_RELEASE_SERVER_FILE=/path/to/content-studio-workbench/dist-server/server.mjs
CONTENT_STUDIO_DATABASE_FILE=/opt/content-studio/data/content-studio.sqlite
CONTENT_STUDIO_ASSET_DIR=/opt/content-studio/data/assets
CONTENT_STUDIO_AUTH_CONFIG_FILE=/opt/content-studio/auth/auth.json

FAL_KEY_FILE=/opt/content-studio/secrets/fal-inference.key
CONTENT_STUDIO_FAL_WORKER_INTERVAL_MS=2500
CONTENT_STUDIO_FAL_LEASE_TTL_MS=15000
CONTENT_STUDIO_FAL_BILLING_RETRY_MS=300000
